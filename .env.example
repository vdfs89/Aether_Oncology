# Aether Oncology — Environment Reference
# Copy to `.env` and fill in. NEVER commit real secrets (.env is gitignored).
# Marked REQUIRED / OPTIONAL. DEV defaults are shown commented (#) where useful.

# ─── [Core API] ───────────────────────────────────────────────────────────────
# REQUIRED in production. Shared key for protected endpoints (header: access_token).
# Fail-closed: if unset in production, protected endpoints return 503.
API_KEY=

# OPTIONAL. "production" (default) = fail-closed auth + no ephemeral keys.
# Set to "dev" to relax auth/secrets for local development.
# AETHER_ENV=production

# ─── [Security / Encryption] ──────────────────────────────────────────────────
# REQUIRED (HIPAA). Persistent Fernet key for the audit trail. Generate once with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# In production NO ephemeral key is generated — without this, audit is not written.
AUDIT_ENCRYPTION_KEY=

# ─── [Database] ───────────────────────────────────────────────────────────────
# OPTIONAL. MongoDB Atlas connection string for the audit store.
# If unset/unreachable, the audit trail falls back to the local JSONL file.
MONGODB_URI=
# OPTIONAL. Mongo namespace (defaults shown).
# AUDIT_MONGO_DB=aether_audit
# AUDIT_MONGO_COLLECTION=audit_trail
# AUDIT_MONGO_ARCHIVE_COLLECTION=audit_trail_archive
# AUDIT_MONGO_ENABLED=true            # "false" forces JSONL even if MONGODB_URI is set

# ─── [Audit / Logging — rotation, archival, retention] ────────────────────────
# OPTIONAL. JSONL rotation (defaults shown).
# AUDIT_ROTATION_ENABLED=true
# AUDIT_MAX_BYTES=10485760            # 10 MB; 0 disables the size cap
# AUDIT_MAX_AGE_HOURS=                # optional time-based rotation
# AUDIT_ROTATION_COMPRESS=true
# OPTIONAL. Archival cron (active -> cold collection) and retention.
# AUDIT_ARCHIVE_ENABLED=true
# AUDIT_RETENTION_DAYS=90             # archive docs older than this
# AUDIT_ARCHIVE_INTERVAL_HOURS=24

# ─── [Observability / Alerts] ─────────────────────────────────────────────────
# OPTIONAL. Slack incoming webhook for real-time audit alerts. Unset = no-op.
SLACK_WEBHOOK_URL=
# OPTIONAL. Alert tuning (defaults shown).
# AUDIT_USAGE_HOURS=8-20              # UTC window for the "0 entries" silence alert
# AUDIT_DECRYPT_ALERT_THRESHOLD=3     # consecutive decrypt failures before alerting
# AUDIT_ALERT_COOLDOWN_SEC=60         # per-(level,title) anti-spam cooldown

# ─── [LLM / Models] ───────────────────────────────────────────────────────────
# OPTIONAL. Gate the EXPERIMENTAL clinical chat copilot only — /predict does NOT
# need these. Without them the copilot is unavailable; diagnosis still works.
OPENAI_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
# OPTIONAL. Provider routing + judge model (defaults resolved in code).
# PRIMARY_REASONING_PROVIDER=groq
# FAST_STREAM_PROVIDER=groq
# CLINICAL_JUDGE_PROVIDER=openai
# OPENAI_JUDGE_MODEL=gpt-4o-mini
# OPTIONAL. Research/RAG (PubMed Entrez) + HuggingFace inference gateway.
# ENTREZ_EMAIL=
# HF_TOKEN=

# ─── [MLOps] ──────────────────────────────────────────────────────────────────
# OPTIONAL. MLflow tracking (default ./mlruns).
# MLFLOW_TRACKING_URI=./mlruns
